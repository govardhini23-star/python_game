import random

score = 0

while True:

    number = random.randint(1,10)
    chances = 3
    print("\n new game is started")

    while chances > 0:
        guess =int(input("guess the number between 1 and 10:"))

        if guess == number:
            print("you win")
            score+=1
            break
        elif guess<number:
            print("too low")
        else:
            print("too high")

            chances -= 1
            print("chance left",chances)
            if chances == 0:
                print(" your game is over the correct number was,", number)
                play_again = input("do you want to play again? (yes/no):)")
                if play_again.lower() != "yes":
                    print("thanks for playing")
                    break